# Copy to `.env.local` and adjust. Next.js loads `.env.local` automatically.

# Backend API base (routes like /public/products, /cms/slug/... live under this path)
NEXT_PUBLIC_API_URL=http://localhost:5001/api
# NEXT_PUBLIC_API_URL=http://76.13.241.251:5001/api

# Optional: server origin for uploaded files (`/uploads/...`). If omitted, the app strips `/api` from NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_ASSET_ORIGIN=http://localhost:5001
# NEXT_PUBLIC_ASSET_ORIGIN=http://76.13.241.251:5001
